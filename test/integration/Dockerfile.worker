FROM ubuntu:24.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    openvswitch-switch \
    iproute2 \
    iputils-ping \
    dnsutils \
    curl \
    bash \
    ca-certificates \
    open-iscsi \
    ceph-common \
    && rm -rf /var/lib/apt/lists/*

# Copy binaries (built by make build build-sim)
COPY bin/cirrus /usr/local/bin/cirrus
COPY bin/libvirtd-sim /usr/local/bin/libvirtd-sim

# Copy entrypoint
COPY test/integration/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
